menu "Clock Configuration"

    menu "WiFi Configuration"
        config WIFI_SSID
            string "WiFi SSID"
            default "Happy"
        config WIFI_PASS
            string "WiFi Password"
            default "ping8275"
    endmenu

    menu "Weather API Configuration"
        config AMAP_KEY
            string "AMAP Weather API Key"
            default "a2dd59be3fc29eded9ac2a4c760871e8"
        config AMAP_CITY
            string "AMAP City Code (adcode)"
            default "330100"
            help
                City code for weather queries, e.g. 330100 for Hangzhou.
                Find yours at https://restapi.amap.com/v3/config/district
    endmenu

    menu "Night Mode Configuration"
        config NIGHT_START_HOUR
            int "Night mode start hour (0-23)"
            range 0 23
            default 20
        config NIGHT_START_MINUTE
            int "Night mode start minute (0-59)"
            range 0 59
            default 30
        config NIGHT_END_HOUR
            int "Night mode end hour (0-23)"
            range 0 23
            default 6
    endmenu

    menu "Sleep Configuration"
        config ACTIVE_DURATION_SECS
            int "Active duration before deep sleep (seconds)"
            default 600
        config WAKEUP_GPIO
            int "Wakeup GPIO number"
            default 3
    endmenu

    menu "GPIO Pin Configuration"
        config PIN_MOSI
            int "SPI MOSI pin"
            default 10
        config PIN_CLK
            int "SPI CLK pin"
            default 7
        config PIN_CS
            int "SPI CS pin (-1 = grounded)"
            default -1
        config PIN_DC
            int "SPI DC pin"
            default 8
        config PIN_RST
            int "SPI RST pin"
            default 20
        config PIN_NS4168_CTRL
            int "NS4168 amplifier control pin"
            default 2
        config BUTTON_GPIO
            int "Button GPIO number"
            default 3
    endmenu

endmenu
