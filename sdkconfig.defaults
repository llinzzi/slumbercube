# Use external 32.768kHz crystal for RTC clock to preserve time during deep sleep
CONFIG_RTC_CLK_SRC_EXT_CRYS=y

# Use custom 1800K factory partition (binary too large for standard 1500K large partition)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Audio player
CONFIG_AUDIO_ENABLE=y
CONFIG_AUDIO_PLAYER_ENABLE_MP3=y
CONFIG_AUDIO_PLAYER_ENABLE_WAV=y
CONFIG_AUDIO_PLAYER_ENABLE_HTTP_STREAM=y
CONFIG_LV_FONT_FMT_TXT_LARGE=y
# CONFIG_LV_FONT_MONTSERRAT_14 is not set

# Night mode: 21:00 → 06:00 (crosses midnight). Pinned here so the
# default in Kconfig.projbuild doesn't drift on rebuilds.
CONFIG_NIGHT_START_HOUR=21
CONFIG_NIGHT_START_MINUTE=0

# ESP32-C3-MINI-1-N4 has 4MB flash; partitions.csv needs the full
# 4032K factory partition, so override the IDF default of 2MB.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Disable HTTPS in esp_http_client — not used, saves heap for audio streaming
# CONFIG_ESP_HTTP_CLIENT_ENABLE_HTTPS is not set

# Enable LVGL QR code widget (used by config_screen)
CONFIG_LV_USE_QRCODE=y

# Reduce LWIP footprint — only 2-3 simultaneous connections needed
CONFIG_LWIP_MAX_SOCKETS=5
CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=8

# Memory optimizations
CONFIG_LV_MEM_SIZE_KILOBYTES=16

# mbedTLS: HTTPS is disabled (see above), so shrink TLS buffers to minimum.
# SSL_IN/OUT buffers are allocated dynamically only when needed; with
# HTTPS fully disabled they stay at 0 heap cost. Pinning a small value
# prevents the Kconfig default (2048) from drifting back on rebuilds.
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=512
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=512
# Reduce certificate bundle — no HTTPS connections are made
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_MAX_CERTS=0
